generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        Int      @id @default(autoincrement())
  email                     String   @unique
  passwordHash              String   @map("password_hash")
  firstName                 String   @map("first_name")
  lastName                  String   @map("last_name")
  role                      UserRole @default(CANDIDATE)
  phone                     String?
  profilePicture            String?  @map("profile_picture")
  linkedinUrl               String?  @map("linkedin_url")
  githubUrl                 String?  @map("github_url")
  bio                       String?
  isVerified                Boolean  @default(false) @map("is_verified")
  isActive                  Boolean  @default(true) @map("is_active")
  isLocked                  Boolean  @default(false) @map("is_locked")
  loginAttempts             Int      @default(0) @map("login_attempts")
  lastLogin                 DateTime? @map("last_login")
  emailVerificationToken    String?  @map("email_verification_token")
  emailVerificationExpires  DateTime? @map("email_verification_expires")
  resetPasswordToken        String?  @map("reset_password_token")
  resetPasswordExpires      DateTime? @map("reset_password_expires")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  // Relations
  candidateProfile CandidateProfile?
  companies        Company[]
  jobs             Job[]
  applications     Application[]
  interviews       Interview[]
  payments         Payment[]
  activityLogs     ActivityLog[]
  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageRecipient")
  subscriptions    Subscription[]
  wallet           Wallet?
  practiceSessions PracticeSession[]

  @@map("users")
}

model Company {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  industry    String?
  size        String?
  website     String?
  // ማስተካከያ፡ ስሙን ከ logoUrl ወደ logo ቀይሬዋለሁ
  logo        String?  @map("logo_url") 
  address     String?
  isVerified  Boolean  @default(false) @map("is_verified")
  createdById Int      @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User  @relation(fields: [createdById], references: [id])
  jobs      Job[]

  @@map("companies")
}

model Job {
  id              Int       @id @default(autoincrement())
  title           String
  description     String
  jobType         String    @default("full-time") @map("job_type")
  experienceLevel String?   @map("experience_level")
  salaryMin       Decimal?  @map("salary_min") @db.Decimal(10, 2)
  salaryMax       Decimal?  @map("salary_max") @db.Decimal(10, 2)
  location        String?
  requiredSkills  String[]  @map("required_skills")
  interviewType   String    @default("technical") @map("interview_type")
  status          JobStatus @default(ACTIVE)
  companyId       Int       @map("company_id")
  createdById     Int       @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company      Company       @relation(fields: [companyId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])
  applications Application[]
  interviews   Interview[]

  @@index([createdById])
  @@index([companyId])
  @@map("jobs")
}

model CandidateProfile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  resumeUrl       String?  @map("resume_url")
  skills          String[]
  experienceLevel String?  @map("experience_level")
  education       Json?
  workExperience  Json?    @map("work_experience")
  certifications  Json?
  languages       String[]
  availability    String?
  expectedSalary  Decimal? @map("expected_salary") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("candidate_profiles")
}

model Application {
  id          Int               @id @default(autoincrement())
  jobId       Int               @map("job_id")
  candidateId Int               @map("candidate_id")
  status      ApplicationStatus @default(PENDING)
  coverLetter String?           @map("cover_letter")
  resumeUrl   String?           @map("resume_url")
  appliedAt   DateTime          @default(now()) @map("applied_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  job       Job  @relation(fields: [jobId], references: [id])
  candidate User @relation(fields: [candidateId], references: [id])

  @@unique([jobId, candidateId])
  @@index([candidateId])
  @@index([jobId])
  @@index([appliedAt])
  @@map("applications")
}

model Interview {
  id                  Int             @id @default(autoincrement())
  jobId               Int             @map("job_id")
  candidateId         Int             @map("candidate_id")
  applicationId       Int?            @map("application_id")
  
  // Interview Content
  questions           Json?
  responses           Json?
  
  // AI Evaluation
  evaluation          Json?
  overallScore        Int?            @map("overall_score")
  technicalScore      Int?            @map("technical_score")
  communicationScore  Int?            @map("communication_score")
  problemSolvingScore Int?            @map("problem_solving_score")
  
  // NEW: Enhanced Scoring
  softSkillsScore     Int?            @map("soft_skills_score")
  confidenceScore     Int?            @map("confidence_score")
  fluencyScore        Int?            @map("fluency_score")
  professionalismScore Int?           @map("professionalism_score")
  integrityScore      Int?            @map("integrity_score")
  integrityRisk       String?         @map("integrity_risk") // LOW, MEDIUM, HIGH
  
  // NEW: Behavioral Analysis
  behavioralMetrics   Json?           @map("behavioral_metrics") // Speech rate, fillers, sentiment
  confidenceMetrics   Json?           @map("confidence_metrics") // Eye contact, facial stability
  
  // NEW: Anti-Cheating Data
  antiCheatData       Json?           @map("anti_cheat_data") // Tab switches, copy-paste attempts
  plagiarismFlags     Json?           @map("plagiarism_flags") // AI-generated content detection
  identityVerification Json?          @map("identity_verification") // Webcam snapshots metadata
  
  // Interview Settings
  interviewMode       String          @default("text") @map("interview_mode") // text, audio, video
  strictnessLevel     String?         @map("strictness_level") // lenient, moderate, strict
  
  status              InterviewStatus @default(PENDING)
  feedback            String?
  startedAt           DateTime?       @map("started_at")
  completedAt         DateTime?       @map("completed_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  job       Job  @relation(fields: [jobId], references: [id])
  candidate User @relation(fields: [candidateId], references: [id])

  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
  @@map("interviews")
}

model Payment {
  id              Int           @id @default(autoincrement())
  userId          Int           @map("user_id")
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("ETB")
  paymentMethod   String        @map("payment_method")
  transactionId   String?       @unique @map("transaction_id")
  chapaReference  String?       @unique @map("chapa_reference")
  status          PaymentStatus @default(PENDING)
  description     String?
  metadata        Json?
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  action      String
  description String?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Message {
  id          Int      @id @default(autoincrement())
  senderId    Int      @map("sender_id")
  recipientId Int      @map("recipient_id")
  subject     String
  body        String
  read        Boolean  @default(false)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sender    User @relation("MessageSender", fields: [senderId], references: [id])
  recipient User @relation("MessageRecipient", fields: [recipientId], references: [id])

  @@index([senderId])
  @@index([recipientId])
  @@index([createdAt])
  @@map("messages")
}

model SubscriptionPlan {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("ETB")
  duration    Int      // in days
  features    String[]
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id            Int      @id @default(autoincrement())
  employerId    Int      @map("employer_id")
  planId        Int      @map("plan_id")
  status        String   @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
  startDate     DateTime @map("start_date")
  endDate       DateTime @map("end_date")
  cancelledAt   DateTime? @map("cancelled_at")
  paymentMethod String?  @map("payment_method")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  employer User @relation(fields: [employerId], references: [id])
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([employerId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  currency  String   @default("ETB")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model WalletTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  amount    Decimal  @db.Decimal(10, 2)
  type      String   // TOPUP, DEDUCT, REFUND
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model CreditBundle {
  id            Int      @id @default(autoincrement())
  name          String
  creditAmount  Int
  priceETB      Decimal  @db.Decimal(10, 2)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("credit_bundles")
}

model PracticeSession {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  topic     String
  difficulty String  @default("medium")
  status    String   @default("active") // active, completed
  startedAt DateTime @map("started_at")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("practice_sessions")
}

enum UserRole {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum JobStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  EXPIRED
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum InterviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

// Dashboard Communication Tables
model DashboardMessage {
  id            Int       @id @default(autoincrement())
  fromDashboard String    // 'candidate', 'employer', 'admin'
  toDashboard   String?   // null means broadcast to all
  eventType     String    // 'APPLICATION_UPDATE', 'INTERVIEW_UPDATE', 'SYSTEM_UPDATE', etc.
  data          String    // JSON stringified data
  timestamp     DateTime  @default(now())
  read          Boolean   @default(false)
  
  @@map("dashboard_messages")
}

model ApplicationActivity {
  id            Int       @id @default(autoincrement())
  applicationId Int
  action        String    // 'STATUS_CHANGED', 'CREATED', 'REJECTED', etc.
  details       String    // JSON stringified details
  timestamp     DateTime  @default(now())
  
  @@map("application_activities")
}

model InterviewActivity {
  id            Int       @id @default(autoincrement())
  interviewId   Int
  action        String    // 'STATUS_CHANGED', 'CREATED', 'COMPLETED', etc.
  details       String    // JSON stringified details
  timestamp     DateTime  @default(now())
  
  @@map("interview_activities")
}

model SystemUpdate {
  id            Int       @id @default(autoincrement())
  adminId       Int
  updateType    String    // 'USER_MANAGEMENT', 'COMPANY_VERIFICATION', 'SYSTEM_ALERT', etc.
  details       String    // JSON stringified details
  timestamp     DateTime  @default(now())
  
  @@map("system_updates")
}

model DashboardNotification {
  id            Int       @id @default(autoincrement())
  dashboard     String    // 'candidate', 'employer', 'admin'
  title         String
  message       String
  type          String    // 'info', 'success', 'warning', 'error'
  data          String?   // JSON stringified data
  read          Boolean   @default(false)
  createdAt     DateTime  @default(now())
  
  @@map("dashboard_notifications")
}
